<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="ClockSystem.WinUI.Views.ClockPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header (Gallery 风格) -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="母钟系统" Style="{StaticResource PageHeaderTitleStyle}"/>
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,6,0,0">
                    <TextBlock Text="{Binding TimeDisplay, Mode=OneWay}"
                               FontFamily="Consolas"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource PrimaryBrush}"/>
                    <TextBlock Text="Master Clock System"
                               FontSize="13"
                               Foreground="{ThemeResource TextMutedBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Style="{StaticResource SecondaryButtonStyle}" Click="OnSyncTimeClicked" ToolTipService.ToolTip="同步系统时间">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE895;" FontSize="14"/>
                        <TextBlock Text="同步系统时间" FontSize="13"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PrimaryButtonStyle}" Click="OnAdjustTimeClicked" ToolTipService.ToolTip="调整时间">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE70F;" FontSize="14"/>
                        <TextBlock Text="调整时间" FontSize="13"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 内容：时钟 + 日志 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="320"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- 时钟卡片 -->
            <Border x:Name="ClockCard" Grid.Column="0"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,12,0"
                    VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <FontIcon Glyph="&#xE823;" Foreground="{ThemeResource PrimaryBrush}" FontSize="18" Margin="0,0,8,0"/>
                        <TextBlock Text="模拟时钟" Style="{StaticResource CardTitleStyle}"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="{ThemeResource Gray50Brush}"
                            CornerRadius="{StaticResource RadiusMd}"
                            Padding="20">
                        <Viewbox Stretch="Uniform">
                            <Canvas x:Name="ClockCanvas" Width="400" Height="400"/>
                        </Viewbox>
                    </Border>
                </Grid>
            </Border>

            <!-- 日志卡片 -->
            <Border Grid.Column="1"
                    Style="{StaticResource CardStyle}"
                    Margin="12,0,0,0"
                    VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <FontIcon Glyph="&#xE9D9;" Foreground="{ThemeResource SecondaryBrush}" FontSize="18" Margin="0,0,8,0"/>
                        <TextBlock Text="系统日志" Style="{StaticResource CardTitleStyle}"/>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{ThemeResource Gray50Brush}" CornerRadius="{StaticResource RadiusSm}" Padding="12,8" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="状态" Style="{StaticResource LabelStyle}" FontSize="11"/>
                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <Ellipse Width="8" Height="8" Fill="{ThemeResource SuccessBrush}"/>
                                    <TextBlock Text="运行中" Style="{StaticResource ValueStyle}" FontSize="13"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="{ThemeResource Gray50Brush}" CornerRadius="{StaticResource RadiusSm}" Padding="12,8" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock Text="报时" Style="{StaticResource LabelStyle}" FontSize="11"/>
                                <TextBlock Text="自动" Style="{StaticResource ValueStyle}" FontSize="13"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="{ThemeResource Gray900Brush}"
                            CornerRadius="{StaticResource RadiusMd}"
                            Padding="12">
                        <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="LogTextBlock"
                                       FontSize="12"
                                       FontFamily="Consolas, Monaco, monospace"
                                       Foreground="{ThemeResource SuccessBrush}"
                                       TextWrapping="Wrap"
                                       LineHeight="20"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
