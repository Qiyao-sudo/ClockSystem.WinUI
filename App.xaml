<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="ClockSystem.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ClockSystem.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 颜色随主题翻转：Light / Dark / Default 三套 -->
            <ResourceDictionary.ThemeDictionaries>

                <!-- ============ 亮色主题 ============ -->
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="PrimaryColor">#2563EB</Color>
                    <Color x:Key="PrimaryDarkColor">#1D4ED8</Color>
                    <Color x:Key="PrimaryLightColor">#3B82F6</Color>
                    <Color x:Key="SecondaryColor">#10B981</Color>
                    <Color x:Key="AccentColor">#F59E0B</Color>
                    <Color x:Key="DangerColor">#EF4444</Color>
                    <Color x:Key="SuccessColor">#10B981</Color>
                    <Color x:Key="WarningColor">#F59E0B</Color>
                    <Color x:Key="InfoColor">#3B82F6</Color>

                    <Color x:Key="Gray50">#F9FAFB</Color>
                    <Color x:Key="Gray100">#F3F4F6</Color>
                    <Color x:Key="Gray200">#E5E7EB</Color>
                    <Color x:Key="Gray300">#D1D5DB</Color>
                    <Color x:Key="Gray400">#9CA3AF</Color>
                    <Color x:Key="Gray500">#6B7280</Color>
                    <Color x:Key="Gray600">#4B5563</Color>
                    <Color x:Key="Gray700">#374151</Color>
                    <Color x:Key="Gray800">#1F2937</Color>
                    <Color x:Key="Gray900">#111827</Color>

                    <Color x:Key="TextPrimaryColor">#111827</Color>
                    <Color x:Key="TextSecondaryColor">#6B7280</Color>
                    <Color x:Key="TextMutedColor">#9CA3AF</Color>

                    <Color x:Key="BackgroundColor">#F9FAFB</Color>
                    <Color x:Key="SurfaceColor">#FFFFFF</Color>
                    <Color x:Key="CardBackgroundColor">#FFFFFF</Color>

                    <Color x:Key="BorderLightColor">#E5E7EB</Color>
                    <Color x:Key="BorderColor">#D1D5DB</Color>
                </ResourceDictionary>

                <!-- ============ 暗色主题 ============ -->
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="PrimaryColor">#60A5FA</Color>
                    <Color x:Key="PrimaryDarkColor">#3B82F6</Color>
                    <Color x:Key="PrimaryLightColor">#93C5FD</Color>
                    <Color x:Key="SecondaryColor">#34D399</Color>
                    <Color x:Key="AccentColor">#FBBF24</Color>
                    <Color x:Key="DangerColor">#F87171</Color>
                    <Color x:Key="SuccessColor">#34D399</Color>
                    <Color x:Key="WarningColor">#FBBF24</Color>
                    <Color x:Key="InfoColor">#60A5FA</Color>

                    <!-- 暗色下灰阶反转：Gray50 作浅色面板背景 → 改为深色 -->
                    <Color x:Key="Gray50">#1E293B</Color>
                    <Color x:Key="Gray100">#243044</Color>
                    <Color x:Key="Gray200">#334155</Color>
                    <Color x:Key="Gray300">#475569</Color>
                    <Color x:Key="Gray400">#64748B</Color>
                    <Color x:Key="Gray500">#94A3B8</Color>
                    <Color x:Key="Gray600">#CBD5E1</Color>
                    <Color x:Key="Gray700">#E2E8F0</Color>
                    <Color x:Key="Gray800">#0B1220</Color>
                    <Color x:Key="Gray900">#020617</Color>

                    <Color x:Key="TextPrimaryColor">#F9FAFB</Color>
                    <Color x:Key="TextSecondaryColor">#CBD5E1</Color>
                    <Color x:Key="TextMutedColor">#94A3B8</Color>

                    <Color x:Key="BackgroundColor">#0F172A</Color>
                    <Color x:Key="SurfaceColor">#1E293B</Color>
                    <Color x:Key="CardBackgroundColor">#1E293B</Color>

                    <Color x:Key="BorderLightColor">#334155</Color>
                    <Color x:Key="BorderColor">#475569</Color>
                </ResourceDictionary>

                <!-- ============ 默认（跟随系统，沿用亮色） ============ -->
                <ResourceDictionary x:Key="Default">
                    <Color x:Key="PrimaryColor">#2563EB</Color>
                    <Color x:Key="PrimaryDarkColor">#1D4ED8</Color>
                    <Color x:Key="PrimaryLightColor">#3B82F6</Color>
                    <Color x:Key="SecondaryColor">#10B981</Color>
                    <Color x:Key="AccentColor">#F59E0B</Color>
                    <Color x:Key="DangerColor">#EF4444</Color>
                    <Color x:Key="SuccessColor">#10B981</Color>
                    <Color x:Key="WarningColor">#F59E0B</Color>
                    <Color x:Key="InfoColor">#3B82F6</Color>

                    <Color x:Key="Gray50">#F9FAFB</Color>
                    <Color x:Key="Gray100">#F3F4F6</Color>
                    <Color x:Key="Gray200">#E5E7EB</Color>
                    <Color x:Key="Gray300">#D1D5DB</Color>
                    <Color x:Key="Gray400">#9CA3AF</Color>
                    <Color x:Key="Gray500">#6B7280</Color>
                    <Color x:Key="Gray600">#4B5563</Color>
                    <Color x:Key="Gray700">#374151</Color>
                    <Color x:Key="Gray800">#1F2937</Color>
                    <Color x:Key="Gray900">#111827</Color>

                    <Color x:Key="TextPrimaryColor">#111827</Color>
                    <Color x:Key="TextSecondaryColor">#6B7280</Color>
                    <Color x:Key="TextMutedColor">#9CA3AF</Color>

                    <Color x:Key="BackgroundColor">#F9FAFB</Color>
                    <Color x:Key="SurfaceColor">#FFFFFF</Color>
                    <Color x:Key="CardBackgroundColor">#FFFFFF</Color>

                    <Color x:Key="BorderLightColor">#E5E7EB</Color>
                    <Color x:Key="BorderColor">#D1D5DB</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- 画笔引用主题色（主题切换时自动重算） -->
            <SolidColorBrush x:Key="PrimaryBrush" Color="{ThemeResource PrimaryColor}" />
            <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{ThemeResource PrimaryDarkColor}" />
            <SolidColorBrush x:Key="PrimaryLightBrush" Color="{ThemeResource PrimaryLightColor}" />
            <SolidColorBrush x:Key="SecondaryBrush" Color="{ThemeResource SecondaryColor}" />
            <SolidColorBrush x:Key="AccentBrush" Color="{ThemeResource AccentColor}" />
            <SolidColorBrush x:Key="DangerBrush" Color="{ThemeResource DangerColor}" />
            <SolidColorBrush x:Key="SuccessBrush" Color="{ThemeResource SuccessColor}" />
            <SolidColorBrush x:Key="WarningBrush" Color="{ThemeResource WarningColor}" />
            <SolidColorBrush x:Key="InfoBrush" Color="{ThemeResource InfoColor}" />

            <SolidColorBrush x:Key="Gray50Brush" Color="{ThemeResource Gray50}" />
            <SolidColorBrush x:Key="Gray100Brush" Color="{ThemeResource Gray100}" />
            <SolidColorBrush x:Key="Gray200Brush" Color="{ThemeResource Gray200}" />
            <SolidColorBrush x:Key="Gray300Brush" Color="{ThemeResource Gray300}" />
            <SolidColorBrush x:Key="Gray400Brush" Color="{ThemeResource Gray400}" />
            <SolidColorBrush x:Key="Gray500Brush" Color="{ThemeResource Gray500}" />
            <SolidColorBrush x:Key="Gray600Brush" Color="{ThemeResource Gray600}" />
            <SolidColorBrush x:Key="Gray700Brush" Color="{ThemeResource Gray700}" />
            <SolidColorBrush x:Key="Gray800Brush" Color="{ThemeResource Gray800}" />
            <SolidColorBrush x:Key="Gray900Brush" Color="{ThemeResource Gray900}" />

            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{ThemeResource TextPrimaryColor}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{ThemeResource TextSecondaryColor}" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="{ThemeResource TextMutedColor}" />

            <SolidColorBrush x:Key="BackgroundBrush" Color="{ThemeResource BackgroundColor}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{ThemeResource SurfaceColor}" />
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="{ThemeResource CardBackgroundColor}" />

            <SolidColorBrush x:Key="BorderLightBrush" Color="{ThemeResource BorderLightColor}" />
            <SolidColorBrush x:Key="BorderBrush" Color="{ThemeResource BorderColor}" />

            <!-- Spacing -->
            <x:Double x:Key="SpacingXs">4</x:Double>
            <x:Double x:Key="SpacingSm">8</x:Double>
            <x:Double x:Key="SpacingMd">16</x:Double>
            <x:Double x:Key="SpacingLg">24</x:Double>
            <x:Double x:Key="SpacingXl">32</x:Double>
            <x:Double x:Key="Spacing2xl">48</x:Double>

            <!-- Border Radius -->
            <CornerRadius x:Key="RadiusSm">4</CornerRadius>
            <CornerRadius x:Key="RadiusMd">8</CornerRadius>
            <CornerRadius x:Key="RadiusLg">12</CornerRadius>
            <CornerRadius x:Key="RadiusXl">16</CornerRadius>
            <CornerRadius x:Key="RadiusFull">9999</CornerRadius>

            <!-- Font Sizes -->
            <x:Double x:Key="FontSizeXs">12</x:Double>
            <x:Double x:Key="FontSizeSm">14</x:Double>
            <x:Double x:Key="FontSizeBase">16</x:Double>
            <x:Double x:Key="FontSizeLg">18</x:Double>
            <x:Double x:Key="FontSizeXl">20</x:Double>
            <x:Double x:Key="FontSize2xl">24</x:Double>
            <x:Double x:Key="FontSize3xl">30</x:Double>
            <x:Double x:Key="FontSize4xl">36</x:Double>

            <!-- Card Style -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource BorderLightBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}" />
                <Setter Property="Padding" Value="{StaticResource SpacingLg}" />
            </Style>

            <!-- Primary Button Style -->
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource PrimaryBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
                <Setter Property="Padding" Value="16,10" />
                <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <!-- Secondary Button Style -->
            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource Gray100Brush}" />
                <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}" />
                <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
                <Setter Property="Padding" Value="16,10" />
                <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <!-- Ghost Button Style -->
            <Style x:Key="GhostButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{ThemeResource PrimaryBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
            </Style>

            <!-- Section Title Style -->
            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource FontSizeXl}" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
            </Style>

            <!-- Card Title Style -->
            <Style x:Key="CardTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource FontSizeLg}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
            </Style>

            <!-- Page Header Title (Gallery 风格大标题) -->
            <Style x:Key="PageHeaderTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource FontSize3xl}" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
            </Style>

            <!-- Label Style -->
            <Style x:Key="LabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
                <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
                <Setter Property="FontWeight" Value="Medium" />
            </Style>

            <!-- Value Style -->
            <Style x:Key="ValueStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource FontSizeBase}" />
                <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
